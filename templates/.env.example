# Kortext v3 runtime config — copy to .env and fill in real values.
# .env is git-ignored. .env.example stays in version control.

# HTTP port the backend listens on (dashboard proxies /api here).
# Backend uses KORTEXT_PORT (not PORT) to avoid collisions with Vite / preview tools.
KORTEXT_PORT=3200

# SQLite database location (relative to project root, or absolute).
KORTEXT_DB_PATH=.kortext/data/kortext.db

# Slack notifications (optional)
SLACK_WEBHOOK_URL=
SLACK_CHANNEL=

# Telegram notifications (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Executor selection (optional — engine auto-detects available CLIs)
# KORTEXT_EXECUTOR=claude | codex | antigravity
