## Kortext v3 runtime config

# HTTP port the backend listens on (dashboard proxies /api here).
# Backend uses KORTEXT_PORT (not PORT) to avoid collisions with Vite / preview tools.
KORTEXT_PORT=3200

# SQLite database location (relative or absolute)
KORTEXT_DB_PATH=.kortext/runtime/kortext.db

# Slack notifications (optional)
SLACK_WEBHOOK_URL=
SLACK_CHANNEL=

# Telegram notifications (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
